{
  "version": 2,
  "builds": [
    {
      "src": "ai_interview_frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "ai_interview_service/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "ai_interview_service/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "ai_interview_frontend/$1"
    }
  ]
}
